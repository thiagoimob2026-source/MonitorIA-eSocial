{
  "event": "S-1200",
  "title": "Remuneração de Trabalhador - RGPS",
  "version": "S-1.3",
  "sections": [
    {
      "name": "Identificação do Trabalhador",
      "fields": [
        {"tag": "cpfTrab", "label": "CPF do Trabalhador", "req": "M", "type": "cpf", "placeholder": "Apenas números", "tip": "Informar o CPF do trabalhador."},
        {"tag": "perApur", "label": "Período (AAAA-MM)", "req": "M", "type": "period", "default": "2026-02", "tip": "Mês/Ano de apuração da folha."},
        {"tag": "nmTrab", "label": "Nome completo", "req": "F", "type": "string", "tip": "Opcional se já cadastrado no eSocial."},
        {"tag": "dtNascto", "label": "Data Nascimento", "req": "F", "type": "date", "placeholder": "DDMMYYYY", "tip": "Obrigatório se não houver cadastro prévio."},
        {"tag": "matricula", "label": "Matrícula", "req": "O", "type": "string", "tip": "Informar se o trabalhador possuir matrícula."}
      ]
    },
    {
      "name": "Dados do Contrato e Lotação",
      "fields": [
        {"tag": "codLotacao", "label": "Cód. Lotação", "req": "M", "type": "string", "default": "1", "tip": "Código da lotação tributária (S-1020)."},
        {"tag": "codCBO", "label": "CBO", "req": "M", "type": "string", "default": "214120", "tip": "Classificação Brasileira de Ocupações."},
        {"tag": "codCateg", "label": "Categoria", "req": "M", "type": "string", "default": "701", "tip": "Categoria do trabalhador (Ex: 701 - Autônomo)."},
        {"tag": "indTetoRGPS", "label": "Ind. Teto RGPS", "req": "M", "type": "options", "values": ["S", "N"], "default": "N", "tip": "Indicativo se o trabalhador atingiu o teto do RGPS em outros vínculos."}
      ]
    }
  ],
  "xml_structure": {
    "root": "evtRemun",
    "sequence": [
      "ideEvento",
      "ideEmpregador",
      "ideTrabalhador",
      "dmDev"
    ],
    "groups": {
      "ideTrabalhador": ["cpfTrab", "infoComplem"],
      "infoComplem": ["nmTrab", "dtNascto"],
      "dmDev": ["ideDmDev", "codCateg", "infoPerApur", "infoComplCont"],
      "infoPerApur": ["ideEstabLot"],
      "ideEstabLot": ["tpInsc", "nrInsc", "codLotacao", "remunPerApur"],
      "remunPerApur": ["matricula", "itensRemun"],
      "infoComplCont": ["codCBO"],
      "itensRemun": ["codRubr", "ideTabRubr", "vrRubr"]
    },
    "mappings": {
      "dmDev": "demonstrativos",
      "itensRemun": "rubrics"
    },
    "conditions": {
      "infoComplem": {
        "if_empty": ["matricula"],
        "if_startswith": {"codCateg": "7"},
        "if_not_empty": ["nmTrab", "dtNascto"]
      },
      "infoComplCont": {
        "if_empty": ["matricula"],
        "if_startswith": {"codCateg": "7"},
        "if_not_empty": ["codCBO", "nmTrab", "dtNascto"]
      }
    }
  }
}
